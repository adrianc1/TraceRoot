<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: category.name }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen flex flex-col">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-4xl mx-auto px-6 py-8 flex-1 w-full">

        <!-- Back link -->
        <a href="/categories"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to categories
        </a>

        <!-- Page header -->
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-gray-900"><%= category.name %></h1>
                <p class="text-sm text-gray-400 font-light mt-0.5"><%= products.length %> product<%= products.length !== 1 ? 's' : '' %> in this category</p>
            </div>
            <div class="flex items-center gap-2">
                <button
                    id="delete-category-btn"
                    data-id="<%= categoryId %>"
                    class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-red-700 border border-red-200 rounded-md hover:bg-red-50 hover:border-red-300 transition-colors cursor-pointer bg-white">
                    Delete
                </button>
                <a href="/categories/<%= categoryId %>/edit"
                   class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 hover:border-gray-400 transition-colors no-underline">
                    Edit
                </a>
            </div>
        </div>

        <!-- Products table card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">

            <% if (!products.length) { %>
                <div class="px-6 py-12 text-center">
                    <p class="text-[0.875rem] text-gray-400">No products in this category yet.</p>
                    <a href="/packages/create-product" class="text-[0.875rem] text-green-mid hover:text-green-deep mt-1 inline-block">
                        Add a product →
                    </a>
                </div>
            <% } else { %>
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-100">
                            <th class="px-6 py-3 text-left text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Name</th>
                            <th class="px-6 py-3 text-left text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Brand</th>
                            <th class="px-6 py-3 text-left text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Strain</th>
                            <th class="px-6 py-3 text-left text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Status</th>
                            <th class="px-6 py-3 text-right text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Quantity</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% products.forEach((product) => { %>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <a href="/packages/<%= product.id %>"
                                   class="text-[0.875rem] font-medium text-green-mid hover:text-green-deep transition-colors no-underline">
                                    <%= product.name %>
                                </a>
                            </td>
                            <td class="px-6 py-4 text-[0.875rem] text-gray-500">
                                <%= product.brand_name || '—' %>
                            </td>
                            <td class="px-6 py-4 text-[0.875rem] text-gray-500">
                                <%= product.strain_name || '—' %>
                            </td>
                            <td class="px-6 py-4">
                                <% if (product.status === 'active') { %>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.75rem] font-medium bg-green-light text-green-deep">
                                        Active
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.75rem] font-medium bg-gray-100 text-gray-500">
                                        Archived
                                    </span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 text-right text-[0.875rem] font-medium text-gray-900">
                                <%= product.total_quantity ? product.total_quantity : 0 %>
                                <span class="text-gray-400 font-normal"><%= product.unit %></span>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>

        </div>
    </div>

    <script src="/js/deleteCategory.js"></script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Edit Category' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen flex flex-col">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-2xl mx-auto px-6 py-8 flex-1 w-full">

        <!-- Back link -->
        <a href="/categories"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to categories
        </a>

        <!-- Page title -->
        <div class="mb-6">
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">Edit Category</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5"><%= category.name %></p>
        </div>

        <%- include('../partials/errors.ejs') %>

        <!-- Form card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <form id="edit-cat-form" data-id="<%= category.id %>">

                <!-- Section: Category Info -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Category Info</div>
                    <div class="space-y-4">

                        <div>
                            <label for="name" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Category Name <span class="text-red-400">*</span>
                            </label>
                            <input
                                type="text"
                                id="name"
                                name="name"
                                value="<%= category.name %>"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white placeholder-gray-300"
                            />
                        </div>

                        <div>
                            <label for="description" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Description
                                <span class="text-[0.75rem] text-gray-400 font-light ml-1">optional</span>
                            </label>
                            <textarea
                                id="description"
                                name="description"
                                rows="3"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all resize-none bg-white placeholder-gray-300"
                            ><%= category.description || '' %></textarea>
                        </div>

                    </div>
                </div>

                <!-- Form actions -->
                <div class="px-6 py-4 bg-gray-50 flex items-center justify-between gap-3">
                    <a href="/categories"
                       class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-white hover:border-gray-400 transition-colors no-underline">
                        Cancel
                    </a>
                    <button
                        type="submit"
                        class="inline-flex items-center justify-center px-5 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer">
                        Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script src="/js/updateCategory.js"></script>

</body>
</html>

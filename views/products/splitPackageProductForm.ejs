<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Split Package' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen flex flex-col">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-2xl mx-auto px-6 py-8 flex-1 w-full">

        <a href="/packages/<%= product.id %>"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to product
        </a>

        <div class="mb-6">
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">Split Package</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5">Create child lots from existing inventory</p>
        </div>

        <div class="space-y-4">

            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="px-6 py-5">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Parent Package</div>
                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">SKU</div>
                            <div class="text-[0.875rem] font-mono font-medium text-gray-800"><%= product.sku %></div>
                        </div>
                        <div>
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Product</div>
                            <div class="text-[0.875rem] font-medium text-gray-800"><%= product.name %></div>
                        </div>
                        <div>
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Available</div>
                            <div class="text-[0.875rem] font-medium text-gray-800">
                                <span id="availableQty"><%= selectedPackage.quantity %></span>
                                <span class="text-gray-400"><%= product.unit %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form card -->
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <form
                    method="POST"
                    action="/packages/<%= selectedPackage.package_tag %>/split"
                    id="splitForm">

                    <div class="px-6 py-5 border-b border-gray-100">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Split Rows</div>
                            <button type="button" id="addRow"
                                class="text-[0.75rem] text-green-mid hover:text-green-deep font-medium transition-colors cursor-pointer">
                                + Add Row
                            </button>
                        </div>

                        <div
                            id="splitRows"
                            class="space-y-3"
                            data-initial-qty="<%= selectedPackage.quantity %>"
                            data-unit="<%= product.unit %>">

                            <div class="split-row grid grid-cols-3 gap-3 p-4 bg-gray-50 border border-gray-200 rounded-lg">
                                <div>
                                    <label class="block text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Package Tag</label>
                                    <input
                                        type="text"
                                        name="packageTag[]"
                                        class="packageTag w-full px-3 py-2 text-[0.875rem] font-mono border border-gray-300 rounded-md bg-white"
                                    />
                                </div>
                                <div>
                                    <label class="block text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Size (<%= product.unit %>)</label>
                                    <input
                                        type="number"
                                        step="0.01"
                                        name="packageSize[]"
                                        class="package-size w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md bg-white"
                                        value="<%= product.package_size || 1 %>"
                                    />
                                    <input type="hidden" name="productId[]" value="<%= product.id %>" />
                                </div>
                                <div>
                                    <label class="block text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Total (<%= product.unit %>)</label>
                                    <input
                                        type="text"
                                        class="total-weight w-full px-3 py-2 text-[0.875rem] border border-gray-200 rounded-md bg-gray-100 text-gray-500 cursor-not-allowed"
                                        readonly
                                    />
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-between text-[0.8125rem] text-gray-500 mb-1">
                            <span>Total Used</span>
                            <span id="totalUsed" class="font-mono">0</span>
                        </div>
                        <div class="flex items-center justify-between text-[0.8125rem] font-medium text-gray-800">
                            <span>Remaining</span>
                            <span id="remainingQty" class="font-mono"><%= selectedPackage.quantity %></span>
                        </div>
                    </div>

                    <div class="px-6 py-4 bg-gray-50 flex items-center justify-between gap-3">
                        <a href="/packages/<%= product.id %>"
                           class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-white hover:border-gray-400 transition-colors no-underline">
                            Cancel
                        </a>
                        <button
                            type="submit"
                            id="submitSplit"
                            class="inline-flex items-center justify-center px-5 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer">
                            Create Split
                        </button>
                    </div>

                </form>
            </div>

        </div>
    </div>

    <script src="/js/splitPackages.js"></script>

</body>
</html>

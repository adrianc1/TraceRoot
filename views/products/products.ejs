<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Packages' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen overflow-x-hidden flex flex-col">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-7xl mx-auto px-4 py-8 flex-1 w-full">

        <!-- Page header -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-3">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-gray-900"><%= message %></h1>
                <p class="text-sm text-gray-500 font-light mt-0.5">All active packages across your inventory</p>
            </div>
            <div class="flex flex-row items-center gap-2">
                <a href="/packages/create-product"
                   class="inline-flex items-center justify-center whitespace-nowrap px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors no-underline">
                    + Add Product
                </a>
                <a href="/packages/receive"
                   class="inline-flex items-center justify-center whitespace-nowrap px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 hover:border-gray-400 transition-colors no-underline">
                    Receive
                </a>
                <a id="export-csv-btn" href="/packages/export?status=<%= currentStatus %>&search=<%= search %>&brand=<%= brand %>&category=<%= category %>&sort=<%= sort %>"
                   class="inline-flex items-center justify-center whitespace-nowrap px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 hover:border-gray-400 transition-colors no-underline">
                    Export CSV
                </a>

            </div>
        </div>

        <!-- Mobile: dropdown -->
        <div class="sm:hidden mb-4">
            <select
                onchange="window.location.href='/packages?status=' + this.value"
                class="w-full px-3 py-2 text-[0.8125rem] border border-gray-300 rounded-md bg-white text-gray-700">
                <% ['all','active', 'inactive', 'quarantine', 'expired', 'damaged', 'reserved'].forEach(s => { %>
                    <option value="<%= s %>" <%= currentStatus === s ? 'selected' : '' %>>
                        <%= s.charAt(0).toUpperCase() + s.slice(1) %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- Desktop: tabs -->
        <div class="hidden sm:flex gap-1 border-b border-gray-200 mb-4">
            <% ['all','active', 'inactive', 'quarantine', 'expired', 'damaged', 'reserved'].forEach(s => { %>
                <a href="/packages?status=<%= s %>"
                class="px-4 py-2 text-[0.8125rem] font-medium border-b-2 transition-colors
                <%= currentStatus === s ? 'border-green-mid text-green-mid' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
                    <%= s.charAt(0).toUpperCase() + s.slice(1) %>
                </a>
            <% }) %>
        </div>



        <!-- ADD FILTER AND SORTING -->

<!-- Filter bar -->
<div class="flex flex-wrap items-center gap-2 mb-4">

    <!-- Search -->
    <div class="relative flex-1 min-w-[200px]">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
        <input
            type="text"
            id="search"
            placeholder="Search tag, product, category..."
            value="<%= search %>"
            class="w-full pl-8 pr-3 py-[0.4rem] text-[0.8125rem] border border-gray-300 rounded-md bg-white transition-all"
        />
    </div>

    <!-- Brand -->
    <select id="filter-brand"
        class="px-3 py-[0.4rem] text-[0.8125rem] border border-gray-300 rounded-md bg-white text-gray-700">
        <option value="">All Brands</option>
        <% brands.forEach(b => { %>
            <option value="<%= b.name %>" <%= brand === b.name ? 'selected' : '' %>><%= b.name %></option>
        <% }) %>
    </select> 

    <!-- Category -->
    <select id="filter-category"
        class="px-3 py-[0.4rem] text-[0.8125rem] border border-gray-300 rounded-md bg-white text-gray-700">
        <option value="">All Categories</option>
        <% categories.forEach(c => { %>
            <option value="<%= c.name %>" <%= category === c.name ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
    </select>

    <!-- Sort -->
    <select id="sort"
        class="px-3 py-[0.4rem] text-[0.8125rem] border border-gray-300 rounded-md bg-white text-gray-700">
        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest</option>
        <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
        <option value="qty_asc" <%= sort === 'qty_asc' ? 'selected' : '' %>>Qty: Low → High</option>
        <option value="qty_desc" <%= sort === 'qty_desc' ? 'selected' : '' %>>Qty: High → Low</option>
        <option value="az" <%= sort === 'az' ? 'selected' : '' %>>A → Z</option>
        <option value="za" <%= sort === 'za' ? 'selected' : '' %>>Z → A</option>
    </select>

    <button onclick="navigate()"
        class="px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors">
        Search
    </button>

</div>


        <!-- Table card -->
        <div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
            <div class="overflow-x-auto">

            <!-- Table -->
            <table class="w-full border-collapse min-w-300">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-50">
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Package Tag</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Product</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Quantity</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Brand</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Category</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Location</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Status</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Cost</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Total Val.</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% packages.forEach((pkg) => { %>
                    <%
                        const statusStyles = {
                            active:     'bg-green-light text-green-deep',
                            inactive:   'bg-gray-100 text-gray-500',
                            quarantine: 'bg-yellow-50 text-yellow-800',
                            damaged:    'bg-red-50 text-red-700',
                            expired:    'bg-slate-50 text-slate-900',
                            reserved:   'bg-blue-50 text-blue-700',
                        };
                        const statusStyle = statusStyles[pkg.status] || 'bg-gray-100 text-gray-500';
                    %>
                   <tr class="hover:bg-gray-50 transition-colors" data-created="<%= pkg.created_at %>">

                        <!-- Package tag -->
                        <td class="px-4 py-3">
                            <span class="font-mono text-[0.75rem] text-gray-500"><%= pkg.package_tag %></span>
                        </td>

                        <!-- Product -->
                        <td class="px-4 py-3">
                            <a href="/packages/<%= pkg.product_id %>"
                               class="text-[0.8125rem] font-medium text-gray-900 hover:text-green-mid transition-colors no-underline">
                                <%= pkg.product_name %>
                            </a>
                            <div class="font-mono text-[0.7rem] text-gray-400 mt-0.5"><%= pkg.strain_name || '—' %></div>
                        </td>
                        <!-- Quantity -->
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] font-semibold text-gray-900"><%= formatQuantity(pkg.quantity, pkg.unit || '') %></span>
                            <span class="text-[0.75rem] text-gray-400 ml-1"><%= pkg.unit || 'each' %></span>
                        </td>

                        <td class="px-4 py-3">
                            <a href="/packages/<%= pkg.product_id %>"
                               class="text-[0.8125rem] font-medium text-gray-900 hover:text-green-mid transition-colors no-underline">
                                <%= pkg.brand_name %>
                            </a>
                        </td>

                        <!-- Category -->
                        <td class="px-4 py-3">
                            <a href="/categories/<%= pkg.category_id %>"
                               class="text-[0.8125rem] text-gray-600 hover:text-green-mid transition-colors no-underline">
                                <%= pkg.category_name %>
                            </a>
                        </td>

                        <!-- Location -->
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] text-gray-600"><%= pkg.location || '—' %></span>
                        </td>

                        <!-- Status badge -->
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center gap-1 font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded capitalize <%= statusStyle %>">
                            <span class="w-1.5 h-1.5 rounded-full bg-current"></span>

                                <%= pkg.status %>
                            </span>
                        </td>

                        <!-- Avg cost -->
                        <td class="px-4 py-3 text-[0.8125rem] text-gray-500">
                            $<%= formatCurrency(pkg.cost_price) %>
                        </td>

                        <!-- Total value -->
                      <td class="px-4 py-3">
                            <span class="text-[0.8125rem] font-semibold text-green-mid">
                                $<%= formatCurrency(pkg.quantity * (pkg.cost_price || 0)) %>
                            </span>
                        </td>

                        <!-- Actions -->
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-3">
                                <a href="/packages/<%= pkg.id %>/adjust/<%= pkg.lot_number %>"
                                   class="text-[0.75rem] text-gray-500 hover:text-gray-700 transition-colors font-medium no-underline">
                                    Adjust
                                </a>
                                <% if (Number(pkg.quantity) > 0) { %>
                                <a href="/packages/<%= pkg.id %>/split/<%= pkg.lot_number %>"
                                   class="text-[0.75rem] text-green-mid hover:text-green-deep transition-colors font-medium no-underline">
                                    Split
                                </a>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            </div>

            <!-- Empty state -->
            <% if (!packages || packages.length === 0) { %>
            <div class="py-8 text-center flex flex-col items-center gap-4">
                <img src="/tracerootlogo.png" alt="Traceroot" class="w-48 opacity-80">
                <p class="text-sm font-medium text-gray-500">No packages yet</p>
                <p class="text-xs text-gray-400">Add a product before receiving inventory</p>
                <a href="/packages/create-product"
                   class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep transition-colors no-underline">
                    Add product
                </a>
            </div>
            <% } %>

            <!-- Table footer -->
            <% if (packages && packages.length > 0) { %>
            <div class="px-4 py-3 border-t border-gray-100 bg-gray-50 flex items-center justify-between">
                <span class="font-mono text-[0.72rem] text-gray-400">
                    <span class="text-gray-600 font-medium"><%= packages.length %></span> packages
                </span>
                <!-- Pagination -->
                <%
                    function pageUrl(p) {
                        const q = new URLSearchParams({ status: currentStatus, page: p });
                        if (search)   q.set('search',   search);
                        if (brand)    q.set('brand',    brand);
                        if (category) q.set('category', category);
                        if (sort && sort !== 'newest') q.set('sort', sort);
                        return '?' + q.toString();
                    }
                %>
                <div class="flex items-center gap-1">
                    <% if (currentPage > 1) { %>
                        <a href="<%= pageUrl(currentPage - 1) %>"
                        class="px-2 py-1 text-[0.75rem] text-gray-500 hover:text-gray-700 font-medium no-underline">← Prev</a>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="<%= pageUrl(i) %>"
                        class="px-2 py-1 text-[0.75rem] rounded no-underline
                        <%= i === currentPage ? 'bg-green-mid text-white font-medium' : 'text-gray-500 hover:text-gray-700' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="<%= pageUrl(currentPage + 1) %>"
                        class="px-2 py-1 text-[0.75rem] text-gray-500 hover:text-gray-700 font-medium no-underline">Next →</a>
                    <% } %>
                </div>

            </div>
            <% } %>
        </div>
    </div>
    <%- include('../partials/footer') %>
<script>
    function navigate() {
        const params = new URLSearchParams();
        params.set('status', '<%= currentStatus %>');
        const search   = document.getElementById('search').value;
        const brand    = document.getElementById('filter-brand').value;
        const category = document.getElementById('filter-category').value;
        const sort     = document.getElementById('sort').value;
        if (search)   params.set('search',   search);
        if (brand)    params.set('brand',    brand);
        if (category) params.set('category', category);
        if (sort && sort !== 'newest') params.set('sort', sort);
        window.location.href = '/packages?' + params.toString();
    }

    document.getElementById('search').addEventListener('keydown', (e) => {
        if (e.key === 'Enter') navigate();
    });
    document.getElementById('filter-brand').addEventListener('change', navigate);
    document.getElementById('filter-category').addEventListener('change', navigate);
    document.getElementById('sort').addEventListener('change', navigate);
</script>
</body>
</html>
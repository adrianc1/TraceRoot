<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
		<link href="/tailwind.css" rel="stylesheet" />

    <title>Edit Product</title>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-2xl mx-auto px-4 py-8">

        <!-- Back link -->
        <a href="/packages/<%= product.id %>"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to product
        </a>

        <!-- Page title -->
        <div class="mb-6">
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">Edit Product</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5"><%= product.name %></p>
        </div>

        <!-- Error partial -->
        <%- include('../partials/errors.ejs') %>

        <!-- Form card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <form method="POST" action="/packages/<%= product.id %>?_method=PUT" id="edit-product-form">

                <!-- Section: Basic Info -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Basic Info</div>
                    <div class="space-y-4">

                        <div>
                            <label for="name" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Product Name <span class="text-red-400">*</span>
                            </label>
                            <input
                                type="text"
                                id="name"
                                name="name"
                                value="<%= product.name %>"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white placeholder-gray-300"
                            />
                        </div>

                        <div>
                            <label for="sku" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                SKU <span class="text-red-400">*</span>
                            </label>
                            <input
                                type="text"
                                id="sku"
                                name="sku"
                                value="<%= product.sku %>"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] font-mono border border-gray-300 rounded-md transition-all bg-white placeholder-gray-300"
                            />
                            <p class="text-[0.75rem] text-gray-400 mt-1">Must be unique within your company</p>
                        </div>

                        <div>
                            <label for="description" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Description
                            </label>
                            <textarea
                                id="description"
                                name="description"
                                rows="3"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all resize-none bg-white placeholder-gray-300"
                            ><%= product.description %></textarea>
                        </div>

                        <div class="w-1/2">
                            <label for="unit" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Unit of Measure <span class="text-red-400">*</span>
                            </label>
                            <select
                                name="unit"
                                id="unit"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white text-gray-700"
                            >
                                <option value="">— Select unit —</option>
                                <% units.forEach((unit) => { %>
                                <option value="<%= unit %>" <%= product.unit === unit ? 'selected' : '' %>><%= unit %></option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- Status -->
                        <div class="w-1/2">
                            <label for="status" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Status
                            </label>
                            <select
                                name="status"
                                id="status"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white text-gray-700"
                            >
                                <option value="active" <%= product.status === 'active' ? 'selected' : '' %>>Active</option>
                                <option value="archived" <%= product.status === 'archived' ? 'selected' : '' %>>Archived</option>
                            </select>
                        </div>

                    </div>
                </div>

                <!-- Section: Classification -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Classification</div>
                    <div class="space-y-4">

                        <!-- Brand -->
                        <div>
                            <label for="brandId" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Brand <span class="text-red-400">*</span>
                            </label>
                            <select
                                name="brandId"
                                id="brandId"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white text-gray-700"
                            >
                                <option value="">— Select a brand —</option>
                                <% brands.forEach((brand) => { %>
                                <option value="<%= brand.id %>" <%= product.brand_id === brand.id ? 'selected' : '' %>><%= brand.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- Category -->
                        <div>
                            <label for="categoryId" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Category <span class="text-red-400">*</span>
                            </label>
                            <select
                                name="categoryId"
                                id="categoryId"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white text-gray-700"
                            >
                                <option value="">— Select a category —</option>
                                <% categories.forEach((category) => { %>
                                <option value="<%= category.id %>" <%= product.category_id === category.id ? 'selected' : '' %>><%= category.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- Strain -->
                        <div>
                            <label for="strainId" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Strain
                                <span class="text-[0.75rem] text-gray-400 font-light ml-1">optional</span>
                            </label>
                            <select
                                name="strainId"
                                id="strainId"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white text-gray-700"
                            >
                                <option value="">— Select a strain —</option>
                                <% strains.forEach((strain) => { %>
                                <option value="<%= strain.id %>" <%= product.strain_id === strain.id ? 'selected' : '' %>><%= strain.name %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Form actions -->
                <div class="px-6 py-4 bg-gray-50 flex items-center justify-between gap-3">
                    <a href="/packages/<%= product.id %>"
                       class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-white hover:border-gray-400 transition-colors no-underline">
                        Cancel
                    </a>
                    <button
                        type="submit"
                        class="inline-flex items-center justify-center px-5 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer">
                        Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script src="/js/productForm.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Receive Inventory' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-2xl mx-auto px-6 py-8">

        <!-- Back link -->
        <a href="/packages/<%= product.id %>"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to product
        </a>

        <!-- Page title -->
        <div class="mb-6">
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">Receive Inventory</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5"><%= product.name %></p>
        </div>

        <!-- Form card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <form
                id="receive-form-pkg"
                data-product_id="<%= product.id %>">

                <!-- Section: Product Info (read-only) -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Product Info</div>
                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Brand</div>
                            <div class="text-[0.875rem] font-medium text-gray-800"><%= brand?.name || '—' %></div>
                        </div>
                        <div>
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Strain</div>
                            <div class="text-[0.875rem] font-medium text-gray-800"><%= strain?.name || '—' %></div>
                        </div>
                        <div>
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Category</div>
                            <div class="text-[0.875rem] font-medium text-gray-800"><%= category?.name || '—' %></div>
                        </div>
                    </div>
                </div>

                <!-- Section: Package Details -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Package Details</div>
                    <div class="space-y-4">

                        <div>
                            <label for="packageTag" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Package Tag <span class="text-red-400">*</span>
                            </label>
                            <input
                                type="text"
                                name="packageTag"
                                id="packageTag"
                                placeholder="e.g. 1A4060300003B01000000001"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] font-mono border border-gray-300 rounded-md transition-all bg-white placeholder-gray-300"
                            />
                        </div>

                        <div>
                            <label for="batch" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Batch Number <span class="text-red-400">*</span>
                            </label>
                            <input
                                type="text"
                                name="batch"
                                id="batch"
                                placeholder="e.g. CCK091827"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] font-mono border border-gray-300 rounded-md transition-all bg-white placeholder-gray-300"
                            />
                        </div>

                        <div>
                            <label for="location_id" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Location <span class="text-red-400">*</span>
                            </label>
                            <select
                                name="location_id"
                                id="location_id"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white text-gray-700"
                            >
                                <option value="">— Select location —</option>
                                <% locations.forEach((loc) => { %>
                                    <option value="<%= loc.id %>"><%= loc.name %></option>
                                <% }) %>
                            </select>
                        </div>

                    </div>
                </div>

                <!-- Section: Quantity & Pricing -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Quantity & Pricing</div>
                    <div class="space-y-4">

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="quantity" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                    Quantity <span class="text-red-400">*</span>
                                </label>
                                <input
                                    type="number"
                                    name="quantity"
                                    id="quantity"
                                    value="0"
                                    min="0"
                                    step="<%= product.unit === 'each' ? '1' : '0.01' %>"
                                    required
                                    class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
                                />
                            </div>

                            <div>
                                <label for="unit" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                    Unit
                                </label>
                                <input
                                    type="text"
                                    value="<%= product.unit %>"
                                    disabled
                                    class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md bg-gray-50 text-gray-500 cursor-not-allowed"
                                />
                                <input type="hidden" name="unit" value="<%= product.unit %>" />
                            </div>
                        </div>

                        <!-- Package size — only shown when unit is 'each' -->
                        <div id="package-size-container" class="<%= product.unit === 'each' ? '' : 'hidden' %>">
                            <label for="package_size" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Weight per Unit (g)
                                <span class="text-[0.75rem] text-gray-400 font-light ml-1">e.g. 3.5 for a 1/8th jar</span>
                            </label>
                            <input
                                type="number"
                                name="package_size"
                                id="package_size"
                                step="0.01"
                                placeholder="3.5"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white placeholder-gray-300"
                            />
                        </div>

                        <div>
                            <label for="unit_price" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Unit Price <span class="text-red-400">*</span>
                            </label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[0.875rem]">$</span>
                                <input
                                    type="number"
                                    name="unit_price"
                                    id="unit_price"
                                    step="0.01"
                                    min="0"
                                    placeholder="0.00"
                                    required
                                    class="w-full pl-7 pr-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
                                />
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Section: Supplier & Notes -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Supplier & Notes</div>
                    <div class="space-y-4">

                        <div>
                            <label for="vendor" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Vendor / Supplier <span class="text-red-400">*</span>
                            </label>
                            <input
                                type="text"
                                name="vendor"
                                id="vendor"
                                placeholder="e.g. Big Weed Holdings"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white placeholder-gray-300"
                            />
                        </div>

                        <div>
                            <label for="notes" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Notes
                                <span class="text-[0.75rem] text-gray-400 font-light ml-1">optional</span>
                            </label>
                            <textarea
                                id="notes"
                                name="notes"
                                rows="3"
                                placeholder="Additional notes..."
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all resize-none bg-white placeholder-gray-300"
                            ></textarea>
                        </div>

                        <input type="hidden" name="reason" value="Receive" />

                    </div>
                </div>

                <!-- Form actions -->
                <div class="px-6 py-4 bg-gray-50 flex items-center justify-between gap-3">
                    <a href="/packages/<%= product.id %>"
                       class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-white hover:border-gray-400 transition-colors no-underline">
                        Cancel
                    </a>
                    <button
                        type="submit"
                        id="edit-btn"
                        class="inline-flex items-center justify-center px-5 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer">
                        Receive Package
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script src="/js/receiveInventory.js"></script>

</body>
</html>

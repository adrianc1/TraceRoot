<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Adjust Quantity' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-2xl mx-auto px-6 py-8">

        <!-- Back link -->
        <a href="/packages/<%= product.id %>"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to product
        </a>

        <!-- Page title -->
        <div class="mb-6">
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">Adjust Quantity</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5"><%= product.name %> — Lot <%= package.lot_number %></p>
        </div>

        <!-- Form card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <form
                id="adjust-form"
                data-id="<%= package.id %>"
                data-lot="<%= package.lot_number %>">

                <!-- Section: Product Info (read-only) -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Package Info</div>
                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Brand</div>
                            <div class="text-[0.875rem] font-medium text-gray-800"><%= brand?.name || '—' %></div>
                        </div>
                        <div>
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Strain</div>
                            <div class="text-[0.875rem] font-medium text-gray-800"><%= strain?.name || '—' %></div>
                        </div>
                        <div>
                            <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Category</div>
                            <div class="text-[0.875rem] font-medium text-gray-800"><%= category?.name || '—' %></div>
                        </div>
                    </div>
                </div>

                <!-- Section: Adjustment -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Adjustment</div>
                    <div class="space-y-4">

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="quantity" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                    Quantity <span class="text-red-400">*</span>
                                </label>
                                <input
                                    type="number"
                                    name="quantity"
                                    id="quantity"
                                    value="<%= package.quantity %>"
                                    step="0.001"
                                    min="0"
                                    required
                                    class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
                                />
                            </div>

                            <div>
                                <label for="unit" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                    Unit
                                </label>
                                <select
                                    name="unit"
                                    id="unit"
                                    class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white text-gray-700"
                                >
                                    <option value="<%= package.unit %>"><%= package.unit || 'each' %></option>
                                    <% units.forEach((unit) => { %>
                                        <option value="<%= unit %>"><%= unit %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <div>
                            <label for="cost_price_unit" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Cost Price <span class="text-red-400">*</span>
                            </label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-[0.875rem]">$</span>
                                <input
                                    type="number"
                                    name="cost_price_unit"
                                    id="cost_price_unit"
                                    value="<%= package.cost_price %>"
                                    step="0.01"
                                    min="0"
                                    required
                                    class="w-full pl-12 pr-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
                                />
                            </div>
                        </div>

                        <div>
                            <label for="movement_type" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Reason <span class="text-red-400">*</span>
                            </label>
                            <select
                                name="movement_type"
                                id="movement_type"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white text-gray-700"
                            >
                                <option value="">— Select a reason —</option>
                                <% adjustmentReasons.forEach((reason) => { %>
                                    <option value="<%= reason %>"><%= reason %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div>
                            <label for="status" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Status
                            </label>
                            <select
                                name="status"
                                id="status"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white text-gray-700"
                            >
                                <option value="<%= package.status %>"><%= package.status %></option>
                                <% statusOptions.forEach((status) => { %>
                                    <option value="<%= status %>"><%= status %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div>
                            <label for="notes" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Notes
                                <span class="text-[0.75rem] text-gray-400 font-light ml-1">optional</span>
                            </label>
                            <textarea
                                id="notes"
                                name="notes"
                                rows="3"
                                placeholder="Additional notes..."
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all resize-none bg-white placeholder-gray-300"
                            ></textarea>
                        </div>

                    </div>
                </div>

                <!-- Form actions -->
                <div class="px-6 py-4 bg-gray-50 flex items-center justify-between gap-3">
                    <a href="/packages/<%= product.id %>"
                       class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-white hover:border-gray-400 transition-colors no-underline">
                        Cancel
                    </a>
                    <button
                        type="submit"
                        id="edit-btn"
                        class="inline-flex items-center justify-center px-5 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer">
                        Update Quantity
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script src="/js/adjustInventory.js"></script>

</body>
</html>

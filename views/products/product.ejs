<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: `Product — ${product.name}` }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-4xl mx-auto px-4 py-8">

        <!-- Back link -->
        <a href="/packages"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to packages
        </a>

        <!-- Product header card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden mb-4">

            <!-- Top bar: name + actions -->
            <div class="px-6 py-5 border-b border-gray-100 flex items-start justify-between gap-4">
                <div>
                    <div class="font-mono text-[0.7rem] text-gray-400 uppercase tracking-[0.08em] mb-1"><%= product.sku %></div>
                    <h1 class="text-xl font-semibold tracking-tight text-gray-900"><%= product.name %>
                    <% if (product.status === 'archived') { %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.7rem] font-medium bg-gray-100 text-gray-500 tracking-wide">
                            Archived
                        </span>
                    <% } %>
                    </h1>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    <% if (product.status === 'archived') { %>
                        <button
                            id="unarchive-btn"
                            data-id="<%= product.id %>"
                            class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-green-700 border border-green-200 rounded-md hover:bg-green-light transition-colors cursor-pointer bg-white">
                            Unarchive
                        </button>
                    <% } else { %>
                        <button
                            id="delete-btn"
                            data-id="<%= product.id %>"
                            class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-red-700 border border-red-200 rounded-md hover:bg-red-50 hover:border-red-300 transition-colors cursor-pointer bg-white">
                            Archive
                        </button>
                    <% } %>
                    <a href="/packages/<%= product.id %>/edit"
                       class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 hover:border-gray-400 transition-colors no-underline">
                        Edit
                    </a>
                    
						<a href="/packages/<%= product.id %>/receive"
						   class="btn-primary">
							+ Receive
						</a>
                </div>
            </div>

            <!-- Valuation stats strip -->
            <div class="grid grid-cols-3 divide-x divide-gray-100 border-b border-gray-100">
                <div class="px-6 py-4">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Avg Cost</div>
                    <div class="text-[1.25rem] font-semibold tracking-tight text-green-mid">
                        $<%= product.average_cost %>
                        <span class="text-[0.8rem] font-normal text-gray-400">/ <%= product.unit %></span>
                    </div>
                </div>
                <div class="px-6 py-4">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Total Quantity</div>
                    <div class="text-[1.25rem] font-semibold tracking-tight text-gray-900">
                        <%= formatQuantity(product.total_quantity, product.unit) %>
                        <span class="ml-1 text-[0.8rem] font-normal text-gray-400">
                            <%= product.unit %>
                        </span>
                        </div>
                </div>
                <div class="px-6 py-4">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Total Valuation</div>
                  <div class="text-[1.25rem] font-semibold tracking-tight text-green-mid">
                    $<%= Number(product.total_valuation || 0).toLocaleString('en-US', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    }) %>
                    </div>
                </div>
            </div>

            <!-- Metadata grid -->
            <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-100">
                <div class="px-6 py-4">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Brand</div>
                    <div class="text-[0.875rem] font-medium text-gray-800"><%= product.brand_name || '—' %></div>
                </div>
                <div class="px-6 py-4">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Strain</div>
                    <div class="text-[0.875rem] font-medium text-gray-800"><%= product.strain_name || '—' %></div>
                </div>
                <div class="px-6 py-4">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Category</div>
                    <div class="text-[0.875rem] font-medium text-gray-800"><%= product.category_name || '—' %></div>
                </div>
                <div class="px-6 py-4">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.06em] mb-1">Unit</div>
                    <div class="text-[0.875rem] font-mono font-medium text-gray-800"><%= product.unit %></div>
                </div>     
            </div>

        </div>

        <!-- Tab nav -->
        <div class="flex items-center gap-1 mb-4 border-b border-gray-200">
            <button id="tab-inventory"
                class="tab-btn px-4 py-2.5 text-[0.8125rem] font-medium text-gray-900 border-b-2 border-gray-900 -mb-px transition-colors"
                data-tab="panel-inventory">
                Active Inventory
            </button>
            <button id="tab-audit"
                class="tab-btn px-4 py-2.5 text-[0.8125rem] font-medium text-gray-400 border-b-2 border-transparent -mb-px hover:text-gray-700 transition-colors"
                data-tab="panel-audit">
                Transaction History
            </button>
        </div>

        <!-- Tab panels -->
        <div id="panel-inventory">
            <%- include('./productInventory', {productInventory}) %>
        </div>
        <div id="panel-audit" class="hidden">
            <%- include('./auditTable', {packages}) %>
        </div>

    </div>

    <script src="/js/auditToggle.js"></script>
    <script src="/js/productActions.js"></script>
    <script>
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => {
                    b.classList.replace('text-gray-900', 'text-gray-400');
                    b.classList.replace('border-gray-900', 'border-transparent');
                });
                btn.classList.replace('text-gray-400', 'text-gray-900');
                btn.classList.replace('border-transparent', 'border-gray-900');

                document.querySelectorAll('#panel-inventory, #panel-audit').forEach(p => p.classList.add('hidden'));
                document.getElementById(btn.dataset.tab).classList.remove('hidden');
            });
        });
    </script>

</body>
</html>
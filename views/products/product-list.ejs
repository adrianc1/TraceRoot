<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Products' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen flex flex-col">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-6xl mx-auto px-4 py-8 flex-1 w-full">

        <!-- Page header -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-3">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-gray-900">Products</h1>
                <p class="text-sm text-gray-400 font-light mt-0.5"><%= products.length %> product<%= products.length !== 1 ? 's' : '' %> in your catalog</p>
            </div>
            <div class="flex flex-row items-center gap-2">
                <a href="/packages/products/export"
                   class="inline-flex items-center justify-center whitespace-nowrap px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 hover:border-gray-400 transition-colors no-underline">
                    Export CSV
                </a>
                <a href="/packages/create-product" class="btn-primary">
                    + New Product
                </a>
            </div>
        </div>

        <!-- Table card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-x-auto">

            <% if (products.length === 0) { %>
                <div class="px-6 py-8 text-center flex flex-col items-center gap-4">
                    <img src="/tracerootlogo.png" alt="Traceroot" class="w-48 opacity-80">
                    <p class="text-[0.875rem] text-gray-400">No products yet.</p>
                    <a href="/packages/create-product" class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep transition-colors no-underline">
                    Create your first product
                    </a>
                </div>
            <% } else { %>
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-100">
                            <th class="px-6 py-3 text-left text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Name</th>
                            <th class="px-6 py-3 text-left text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Brand</th>
                            <th class="px-6 py-3 text-left text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Category</th>
                            <th class="px-6 py-3 text-left text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Strain</th>
                            <th class="px-6 py-3 text-right text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">On Hand</th>
                            <th class="px-6 py-3 text-right text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Avg Cost</th>
                            <th class="px-6 py-3 text-left text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Status</th>
                            <th class="px-6 py-3 text-right text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% products.forEach((product) => { %>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 text-[0.875rem] font-medium text-gray-900">
                                <%= product.name %>
                                <!-- <% if (product.unit) { %>
                                    <span class="text-[0.75rem] text-gray-400 font-normal ml-1">(<%= product.unit %>)</span>
                                <% } %> -->
                            </td>
                            <td class="px-6 py-4 text-[0.875rem] text-gray-500"><%= product.brand_name || '—' %></td>
                            <td class="px-6 py-4 text-[0.875rem] text-gray-500"><%= product.category_name || '—' %></td>
                            <td class="px-6 py-4 text-[0.875rem] text-gray-500"><%= product.strain_name || '—' %></td>
                            <td class="px-6 py-4 text-[0.875rem] text-gray-900 text-right font-mono">
                                <%= formatQuantity(product.product_qty) %>
                                <%= product.unit ? product.unit : '' %>
                            </td>
                            <td class="px-6 py-4 text-[0.875rem] text-gray-500 text-right font-mono">
                                $<%= product.average_cost > 0 ? formatCurrency(product.average_cost) : '—' %>
                            </td>
                            <td class="px-6 py-4">
                                <% if (product.status === 'archived') { %>
                                    <span class="inline-flex items-center font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded bg-gray-100 text-gray-500">Archived</span>
                                <% } else { %>
                                    <span class="inline-flex items-center font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded bg-green-light text-green-deep">Active</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="inline-flex items-center gap-2">
                                    <a href="/packages/<%= product.id %>"
                                       class="inline-flex items-center justify-center px-3 py-[0.35rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 hover:border-gray-400 transition-colors no-underline">
                                        Packages
                                    </a>
                                    <a href="/packages/<%= product.id %>/edit"
                                       class="inline-flex items-center justify-center px-3 py-[0.35rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 hover:border-gray-400 transition-colors no-underline">
                                        Edit
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>

        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>

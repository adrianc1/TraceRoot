<div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
    <div class="overflow-x-auto">
        <table class="w-full border-collapse">
            <thead>
                <tr class="border-b border-gray-200 bg-gray-50">
                    <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Package Tag</th>
                    <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Location</th>
                    <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Quantity</th>
                    <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Cost</th>
                    <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Total Val.</th>
                    <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Status</th>
                    <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% productInventory.forEach(package => { %>
                <%
                    const statusStyles = {
                        active:     'bg-green-light text-green-deep',
                        inactive:   'bg-gray-100 text-gray-500',
                        quarantine: 'bg-yellow-50 text-yellow-800',
                        damaged:    'bg-red-50 text-red-700',
                        expired:    'bg-slate-50 text-slate-900',
                        reserved:   'bg-blue-50 text-blue-700',
                    };
                    const statusStyle = statusStyles[package.status] || 'bg-gray-100 text-gray-500';
                %>
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3">
                        <span class="font-mono text-[0.75rem] text-gray-500"><%= package.package_tag %></span>
                    </td>
                    <td class="px-4 py-3">
                        <span class="text-[0.8125rem] text-gray-600"><%= package.location || '—' %></span>
                    </td>
                    <td class="px-4 py-3">
                        <span class="text-[0.8125rem] font-semibold text-gray-900"><%= formatQuantity(package.quantity, product.unit) %></span>
                        <span class="text-[0.75rem] text-gray-400 ml-1"><%= product.unit %></span>
                    </td>
                    <td class="px-4 py-3 text-[0.8125rem] text-gray-500">
                        $<%= formatCurrency(package.cost_price) %>
                    </td>
                    <td class="px-4 py-3">
                        <span class="text-[0.8125rem] font-semibold text-green-mid">
                            $<%= formatCurrency(package.quantity * (package.cost_price || 0)) %>
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <span class="inline-flex items-center gap-1 font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded capitalize <%= statusStyle %>">
                            <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                            <%= package.status %>
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-3">
                            <a href="/packages/<%= package.package_tag %>/adjust"
                               class="text-[0.75rem] text-gray-500 hover:text-gray-700 transition-colors font-medium no-underline">Adjust</a>
                            <% if (package.quantity > 0) { %>
                            <a href="/packages/<%= package.package_tag %>/split"
                               class="text-[0.75rem] text-green-mid hover:text-green-deep transition-colors font-medium no-underline">Split</a>
                            <% } %>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <% if (!productInventory || productInventory.length === 0) { %>
    <div class="py-8 text-center">
        <p class="text-sm font-medium text-gray-500">No packages received yet</p>
    </div>
    <% } %>

    <% if (productInventory && productInventory.length > 0) { %>
    <div class="px-4 py-3 border-t border-gray-100 bg-gray-50">
        <span class="font-mono text-[0.72rem] text-gray-400">
            <span class="text-gray-600 font-medium"><%= productInventory.length %></span> packages
        </span>
    </div>
    <% } %>
</div>

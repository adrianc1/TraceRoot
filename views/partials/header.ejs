<header
	class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-200"
>
	<div
		class="max-w-7xl mx-auto px-6 h-[60px] flex items-center justify-between"
	>
		<!-- Logo -->
		<a href="/packages" class="flex items-center gap-2 no-underline shrink-0">
			<img src="/tracerootheader.png" alt="TraceRoot" class="h-7" />
		</a>

		<!-- Nav links -->
		<nav class="hidden md:flex items-center gap-7">
			<a
				href="/packages"
				class="text-[0.8125rem] text-gray-600 hover:text-gray-900 transition-colors no-underline"
			>
				Packages
			</a>
			<a
				href="/categories"
				class="text-[0.8125rem] text-gray-600 hover:text-gray-900 transition-colors no-underline"
			>
				Categories
			</a>
			<a
				href="/strains"
				class="text-[0.8125rem] text-gray-600 hover:text-gray-900 transition-colors no-underline"
			>
				Strains
			</a>
			<a
				href="/brands"
				class="text-[0.8125rem] text-gray-600 hover:text-gray-900 transition-colors no-underline"
			>
				Brands
			</a>

			<a
				href="/transfers"
				class="text-[0.8125rem] text-gray-600 hover:text-gray-900 transition-colors no-underline"
			>
				Transfers
			</a>
		</nav>

		<!-- Right: user dropdown -->
		<div class="relative" id="user-menu">
			<button
				id="user-menu-btn"
				class="flex items-center gap-2 px-3 py-1.5 rounded-md hover:bg-gray-100 transition-colors cursor-pointer border-none bg-transparent"
			>
				<!-- Avatar initials -->
				<div
					class="w-7 h-7 rounded-full bg-green-light flex items-center justify-center shrink-0"
				>
					<span class="text-[0.7rem] font-semibold text-green-deep font-mono">
						<%= locals.firstName ? locals.firstName[0].toUpperCase() : '?' %>
					</span>
				</div>
				<span class="text-[0.8125rem] text-gray-700 font-medium"
					><%= locals.firstName %></span
				>
				<!-- Chevron -->
				<svg
					id="chevron"
					class="w-3.5 h-3.5 text-gray-400 transition-transform duration-150"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M19 9l-7 7-7-7"
					/>
				</svg>
			</button>

			<!-- Dropdown -->
			<div
				id="user-dropdown"
				class="hidden absolute right-0 top-[calc(100%+6px)] w-52 bg-white border border-gray-200 rounded-xl shadow-lg overflow-hidden z-50"
			>
				<!-- User info header -->
				<div class="px-4 py-3 border-b border-gray-100">
					<div class="text-[0.8125rem] font-medium text-gray-900">
						<%= locals.firstName %>
					</div>
					<div class="text-[0.75rem] text-gray-400 font-mono mt-0.5">
						<%= locals.email || '' %>
					</div>
				</div>

				<!-- Menu items -->
				<div class="py-1">
					<a
						href="/account"
						class="flex items-center gap-3 px-4 py-2.5 text-[0.8125rem] text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors no-underline"
					>
						<svg
							class="w-4 h-4 text-gray-400 shrink-0"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
							/>
						</svg>
						Account
					</a>
					<a
						href="/settings"
						class="flex items-center gap-3 px-4 py-2.5 text-[0.8125rem] text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors no-underline"
					>
						<svg
							class="w-4 h-4 text-gray-400 shrink-0"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
							/>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
							/>
						</svg>
						Settings
					</a>
				</div>

				<!-- Logout -->
				<div class="py-1 border-t border-gray-100">
					<a
						href="/logout"
						class="flex items-center gap-3 px-4 py-2.5 text-[0.8125rem] text-red-600 hover:bg-red-50 transition-colors no-underline"
					>
						<svg
							class="w-4 h-4 text-red-400 shrink-0"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
							/>
						</svg>
						Log out
					</a>
				</div>
			</div>
		</div>
	</div>
</header>

<script>
	(() => {
		const btn = document.getElementById('user-menu-btn');
		const menu = document.getElementById('user-dropdown');
		const chevron = document.getElementById('chevron');

		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			const isOpen = !menu.classList.contains('hidden');
			menu.classList.toggle('hidden', isOpen);
			chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
		});

		document.addEventListener('click', () => {
			menu.classList.add('hidden');
			chevron.style.transform = '';
		});
	})();
</script>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Transfers' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-7xl mx-auto px-6 py-8">

        <!-- page header -->
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-gray-900">Transfers</h1>
                <p class="text-sm text-gray-400 font-light mt-0.5">All inventory transfers for your company</p>
            </div>
            <a href="/transfers/create"
               class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors no-underline">
                + New Transfer
            </a>
        </div>

        <!-- table contaaner -->
        <div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-50">
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">#</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Type</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">From</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">To</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Packages</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Status</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Date</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% transfers.forEach((t) => { %>
                    <%
                        const statusStyles = {
                            pending:   'bg-amber-50 text-amber-700',
                            confirmed: 'bg-green-light text-green-deep',
                            cancelled: 'bg-gray-100 text-gray-500',
                        };
                        const statusStyle = statusStyles[t.status] || 'bg-gray-100 text-gray-500';
                        const typeStyles = {
                            internal: 'bg-blue-50 text-blue-700',
                            external: 'bg-purple-50 text-purple-700',
                        };
                        const typeStyle = typeStyles[t.transfer_type] || 'bg-gray-100 text-gray-500';
                    %>
                    <tr class="hover:bg-gray-50 transition-colors">

                        <!-- transfer id -->
                        <td class="px-4 py-3">
                            <span class="font-mono text-[0.75rem] text-gray-500">#<%= t.id %></span>
                        </td>

                        <!-- type -->
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded capitalize <%= typeStyle %>">
                                <%= t.transfer_type %>
                            </span>
                        </td>

                        <!-- from -->
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] text-gray-700"><%= t.from_location %></span>
                        </td>

                        <!-- To -->
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] text-gray-700">
                                <%= t.to_location || t.to_company_name || '—' %>
                            </span>
                        </td>

                        <!-- Packge count -->
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] font-semibold text-gray-900"><%= t.package_count %></span>
                        </td>

                        <!-- Status -->
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded capitalize <%= statusStyle %>">
                                <%= t.status %>
                            </span>
                        </td>

                        <!-- DAte -->
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] text-gray-400">
                                <%= new Date(t.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                            </span>
                        </td>

                        <!-- Actions -->
                        <td class="px-4 py-3">
                            <a href="/transfers/<%= t.id %>"
                               class="text-[0.75rem] text-gray-400 hover:text-gray-700 transition-colors font-medium no-underline">
                                View
                            </a>
                        </td>

                    </tr>
                    <% }) %>
                </tbody>
            </table>

            <!-- empty state if htere are no transfers -->
            <% if (!transfers || transfers.length === 0) { %>
            <div class="py-16 text-center">
                <div class="text-gray-300 text-4xl mb-3">⇄</div>
                <p class="text-sm font-medium text-gray-500">No transfers yet</p>
                <p class="text-xs text-gray-400 mt-1 mb-4">Create your first transfer to move inventory</p>
                <a href="/transfers/create"
                   class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep transition-colors no-underline">
                    New Transfer
                </a>
            </div>
            <% } %>

            <!-- Table footer -->
            <% if (transfers && transfers.length > 0) { %>
            <div class="px-4 py-3 border-t border-gray-100 bg-gray-50">
                <span class="font-mono text-[0.72rem] text-gray-400">
                    <span class="text-gray-600 font-medium"><%= transfers.length %></span> transfers
                </span>
            </div>
            <% } %>
        </div>
    </div>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Transfer #' + transfer.id }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-4xl mx-auto px-6 py-8">

        <a href="/transfers"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to transfers
        </a>

        <!-- Page header -->
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-gray-900">Transfer #<%= transfer.id %></h1>
                <p class="text-sm text-gray-400 font-light mt-0.5">
                    Created by <%= transfer.created_by %> on <%= new Date(transfer.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </p>
            </div>

            <!-- Actions -->
            <% if (transfer.status === 'pending') { %>
            <div class="flex items-center gap-2">
                <button
                    onclick="cancelTransfer(<%= transfer.id %>)"
                    class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 hover:border-gray-400 transition-colors cursor-pointer">
                    Cancel
                </button>
                <button
                    onclick="confirmTransfer(<%= transfer.id %>)"
                    class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer">
                    Confirm Transfer
                </button>
            </div>
            <% } %>
        </div>

        <!-- Meta card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden mb-6">
            <div class="px-6 py-4 border-b border-gray-100">
                <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Transfer Details</div>
            </div>
            <div class="px-6 py-5 grid grid-cols-2 gap-6">

                <div>
                    <div class="text-[0.75rem] text-gray-400 mb-1">Type</div>
                    <%
                        const typeStyles = { internal: 'bg-blue-50 text-blue-700', external: 'bg-purple-50 text-purple-700' };
                        const typeStyle = typeStyles[transfer.transfer_type] || 'bg-gray-100 text-gray-500';
                    %>
                    <span class="inline-flex items-center font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded capitalize <%= typeStyle %>">
                        <%= transfer.transfer_type %>
                    </span>
                </div>

                <div>
                    <div class="text-[0.75rem] text-gray-400 mb-1">Status</div>
                    <%
                        const statusStyles = {
                            pending:   'bg-amber-50 text-amber-700',
                            confirmed: 'bg-green-light text-green-deep',
                            cancelled: 'bg-gray-100 text-gray-500',
                        };
                        const statusStyle = statusStyles[transfer.status] || 'bg-gray-100 text-gray-500';
                    %>
                    <span class="inline-flex items-center font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded capitalize <%= statusStyle %>">
                        <%= transfer.status %>
                    </span>
                </div>

                <div>
                    <div class="text-[0.75rem] text-gray-400 mb-1">From</div>
                    <div class="text-[0.8125rem] font-medium text-gray-900"><%= transfer.from_location %></div>
                </div>

                <div>
                    <div class="text-[0.75rem] text-gray-400 mb-1">To</div>
                    <div class="text-[0.8125rem] font-medium text-gray-900">
                        <%= transfer.to_location || transfer.to_company_name || '—' %>
                    </div>
                </div>

                <% if (transfer.confirmed_at) { %>
                <div>
                    <div class="text-[0.75rem] text-gray-400 mb-1">Confirmed At</div>
                    <div class="text-[0.8125rem] text-gray-700">
                        <%= new Date(transfer.confirmed_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                    </div>
                </div>
                <% } %>

                <% if (transfer.notes) { %>
                <div class="col-span-2">
                    <div class="text-[0.75rem] text-gray-400 mb-1">Notes</div>
                    <div class="text-[0.8125rem] text-gray-700"><%= transfer.notes %></div>
                </div>
                <% } %>

            </div>
        </div>

        <!-- Line items -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Packages</div>
            </div>
            <table class="w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-50">
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Package Tag</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Product</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Category</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Transfer Qty</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Cost Per Unit</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% transfer.items.forEach((item) => { %>
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-4 py-3">
                            <span class="font-mono text-[0.75rem] text-gray-500"><%= item.package_tag %></span>
                        </td>
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] font-medium text-gray-900"><%= item.product_name %></span>
                        </td>
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] font-medium text-gray-900"><%= item.category_name %></span>
                        </td>
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] font-semibold text-gray-900"><%= item.quantity %> <%= item.unit %></span>
                        </td>

                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] text-gray-500">$ <%= item.cost_price %></span>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <div class="flex justify-between px-4 py-3 border-t border-gray-100 bg-gray-50">
                <span class="font-mono text-[0.72rem] text-gray-400">
                    <span class="text-gray-600 font-medium"><%= transfer.items.length %></span> packages
                </span>
                <span class="font-mono text-[0.72rem] text-gray-400">
                    Total: <span class="text-gray-600 font-medium">
                        $<%= transfer.items.reduce((sum, item) => sum + (parseFloat(item.cost_price) * parseFloat(item.quantity)), 0).toFixed(2) %>
                    </span>
                </span>
            </div>
        </div>
    </div>

    <script>
        async function confirmTransfer(id) {
            const res = await fetch(`/transfers/${id}/confirm`, { method: 'PUT' });
            if (res.ok) window.location.reload();
            else alert('Could not confirm transfer');
        }

        async function cancelTransfer(id) {
            const res = await fetch(`/transfers/${id}/cancel`, { method: 'PUT' });
            if (res.ok) window.location.reload();
            else alert('Could not cancel transfer');
        }
    </script>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'New Transfer' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-2xl mx-auto px-6 py-8">

        <a href="/transfers"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to transfers
        </a>

        <div class="mb-6">
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">New Transfer</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5">Move inventory between locations or to an external company</p>
        </div>

        <!-- Form card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <form method="POST" action="/transfers" id="create-transfer-form">

                <!-- Section -- Transfer Info -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Transfer Info</div>
                    <div class="space-y-4">

                        <!-- Type -->
                        <div>
                            <label class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Transfer Type <span class="text-red-400">*</span>
                            </label>
                            <select
                                name="transfer_type"
                                id="transfer_type"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md bg-white text-gray-700"
                            >
                                <option value="">— Select type —</option>
                                <option value="internal">Internal</option>
                                <option value="external">External</option>
                            </select>
                        </div>

                        <!-- From location -->
                        <div>
                            <label class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                From Location <span class="text-red-400">*</span>
                            </label>
                            <select
                                name="from_location_id"
                                id="from_location_id"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md bg-white text-gray-700"
                            >
                                <option value="">— Select location —</option>
                                <% locations.forEach((loc) => { %>
                                <option value="<%= loc.id %>"><%= loc.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- To location (internal) -->
                        <div id="to-location-wrapper">
                            <label class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                To Location <span class="text-red-400">*</span>
                            </label>
                            <select
                                name="to_location_id"
                                id="to_location_id"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md bg-white text-gray-700"
                            >
                                <option value="">— Select location —</option>
                                <% locations.forEach((loc) => { %>
                                <option value="<%= loc.id %>"><%= loc.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- To company (external) -->
                        <div id="to-company-wrapper" class="hidden">
                            <label class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Destination Company <span class="text-red-400">*</span>
                            </label>
                            <input
                                type="text"
                                name="to_company_name"
                                id="to_company_name"
                                placeholder="Acme Dispensary"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md bg-white placeholder-gray-300"
                            />
                        </div>

                        <!-- Notes -->
                        <div>
                            <label class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Notes
                                <span class="text-[0.75rem] text-gray-400 font-light ml-1">optional</span>
                            </label>
                            <textarea
                                name="notes"
                                rows="2"
                                placeholder="Any additional context..."
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md resize-none bg-white placeholder-gray-300"
                            ></textarea>
                        </div>

                    </div>
                </div>

                <!-- Section: packages -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="flex items-center justify-between mb-4">
                        <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Packages</div>
                        <button type="button" onclick="addItem()"
                            class="text-[0.75rem] text-green-mid hover:text-green-deep font-medium transition-colors cursor-pointer">
                            + Add Package
                        </button>
                    </div>

                    <div id="items-list" class="space-y-3">
                        <!-- rows injected by js -->
                    </div>

                    <p id="no-items-msg" class="text-[0.8125rem] text-gray-400 italic">No packages added yet</p>
                </div>

                <!-- Form actions -->
                <div class="px-6 py-4 bg-gray-50 flex items-center justify-between gap-3">
                    <a href="/transfers"
                       class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-white hover:border-gray-400 transition-colors no-underline">
                        Cancel
                    </a>
                    <button
                        type="submit"
                        class="inline-flex items-center justify-center px-5 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer">
                        Create Transfer
                    </button>
                </div>

            </form>
        </div>
    </div>

<script>
    const pkgList = <%- JSON.stringify(packages) %>;
    let filteredPackages = [];
    let itemCount = 0;

    document.getElementById('from_location_id').addEventListener('change', function() {
        const selectedLocation = this.options[this.selectedIndex].text;
        filteredPackages = pkgList.filter(p => p.location === selectedLocation);
        document.getElementById('items-list').innerHTML = '';
        checkEmpty();
    });

    function addItem() {
        if (!filteredPackages.length) {
            alert('Please select a from location first');
            return;
        }

        const list = document.getElementById('items-list');
        const msg = document.getElementById('no-items-msg');
        msg.classList.add('hidden');

        const options = filteredPackages.map(p =>
            `<option data-quantity="${p.quantity}" value="${p.id}">${p.package_tag} — ${p.quantity} ${p.unit}</option>`
        ).join('');

        const row = document.createElement('div');
        row.className = 'flex items-center gap-3';
        row.innerHTML = `
            <select
                name="items[${itemCount}][package_id]"
                required
                onchange="this.nextElementSibling.value = this.options[this.selectedIndex].dataset.quantity || ''"
                class="w-full px-3 py-2 text-[0.875rem] font-mono border border-gray-300 rounded-md bg-white text-gray-700"
            >
                <option value="" data-quantity="">— Select package —</option>
                ${options}
            </select>
            <input type="hidden" name="items[${itemCount}][quantity]" value="" />
            <button type="button" onclick="this.parentElement.remove(); checkEmpty()"
                class="text-gray-300 hover:text-red-400 transition-colors text-lg cursor-pointer">
                ×
            </button>
        `;
        list.appendChild(row);
        itemCount++;
    }

    function checkEmpty() {
        const list = document.getElementById('items-list');
        const msg = document.getElementById('no-items-msg');
        if (list.children.length === 0) msg.classList.remove('hidden');
    }

    document.getElementById('transfer_type').addEventListener('change', function () {
        const toLocation = document.getElementById('to-location-wrapper');
        const toCompany = document.getElementById('to-company-wrapper');
        const toLocationSelect = document.getElementById('to_location_id');
        const toCompanyInput = document.getElementById('to_company_name');

        if (this.value === 'external') {
            toLocation.classList.add('hidden');
            toCompany.classList.remove('hidden');
            toLocationSelect.removeAttribute('required');
            toCompanyInput.setAttribute('required', true);
        } else {
            toLocation.classList.remove('hidden');
            toCompany.classList.add('hidden');
            toLocationSelect.setAttribute('required', true);
            toCompanyInput.removeAttribute('required');
        }
    });
</script>

</body>
</html>
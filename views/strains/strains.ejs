<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Strains' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen overflow-x-hidden flex flex-col">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-7xl mx-auto px-6 py-8 flex-1 w-full">

        <!-- Page header -->
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-gray-900">Strains</h1>
                <p class="text-sm text-gray-500 font-light mt-0.5"><%= strains.length %> strain<%= strains.length !== 1 ? 's' : '' %> in your company</p>
            </div>
            <a href="/strains/create-strain"
               class="inline-flex items-center justify-center whitespace-nowrap px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors no-underline">
                + New Strain
            </a>
        </div>

        <!-- Table card -->
        <div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
            <div class="overflow-x-auto">

            <table class="w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-50">
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Name</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Type</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Description</th>
                        <th class="text-right text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% strains.forEach((strain) => { %>
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] font-medium text-gray-900"><%= strain.name %></span>
                        </td>
                        <td class="px-4 py-3">
                            <% if (strain.type) { %>
                                <span class="inline-flex items-center px-2 py-0.5 rounded font-mono text-[0.7rem] font-medium
                                    <% if (strain.type === 'Indica') { %>bg-purple-100 text-purple-700
                                    <% } else if (strain.type === 'Sativa') { %>bg-orange-100 text-orange-700
                                    <% } else if (strain.type === 'Hybrid') { %>bg-gray-100 text-gray-700
                                    <% } else if (strain.type === 'Indica-Dominant') { %>bg-blue-50 text-blue-700
                                    <% } else if (strain.type === 'Sativa-Dominant') { %>bg-amber-50 text-amber-700
                                    <% } else { %>bg-gray-100 text-gray-700
                                    <% } %>">
                                    <%= strain.type.charAt(0).toUpperCase() + strain.type.slice(1) %>
                                </span>
                            <% } else { %>
                                <span class="text-[0.8125rem] text-gray-400">—</span>
                            <% } %>
                        </td>
                        <td class="px-4 py-3 text-[0.8125rem] text-gray-500">
                            <%= strain.description || '—' %>
                        </td>
                        <td class="px-4 py-3 text-right">
                            <a href="/strains/<%= strain.id %>/edit"
                               class="text-[0.75rem] text-gray-500 hover:text-gray-700 transition-colors font-medium no-underline">
                                Edit
                            </a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>

            </div><!-- /overflow-x-auto -->

            <!-- Empty state -->
            <% if (strains.length === 0) { %>
            <div class="py-16 text-center">
                <img src="/tracerootlogo.png" alt="Traceroot" class="w-48 opacity-80 mx-auto mb-3">
                <p class="text-sm font-medium text-gray-500">No strains yet</p>
                <p class="text-xs text-gray-400 mt-1 mb-4">Create your first strain to get started</p>
                <a href="/strains/create-strain"
                   class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep transition-colors no-underline">
                    New Strain
                </a>
            </div>
            <% } %>

            <!-- Table footer -->
            <% if (strains.length > 0) { %>
            <div class="px-4 py-3 border-t border-gray-100 bg-gray-50">
                <span class="font-mono text-[0.72rem] text-gray-400">
                    <span class="text-gray-600 font-medium"><%= strains.length %></span> strain<%= strains.length !== 1 ? 's' : '' %>
                </span>
            </div>
            <% } %>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>

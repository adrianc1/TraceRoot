<!DOCTYPE html>
<html lang="en">
	<head>
    <%- include('../partials/head', { title: 'Create Strain' }) %>
</head>
	<body>
		<%- include ('../partials/header.ejs') %>

		<button>
			<a
				class="inline-flex items-center text-green-600 hover:text-green-700 font-medium mb-6 transition-colors"
				href="/strains/"
				>← Back to strains</a
			>
		</button>

		<div class="bg-white rounded-lg shadow-md p-8">
			<h1 class="text-3xl font-bold text-gray-800 mb-6">Create Strain</h1>
			<form action="/strains/create-strain" method="POST" class="space-y-6">
				<label
					for="strain-name"
					class="block text-sm font-semibold text-gray-700 mb-2"
					>Strain Name:
				</label>
				<input
					type="text"
					id="strain-name"
					name="name"
					value=""
					class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors"
				/>
				<label
					for="strain-description"
					class="block text-sm font-semibold text-gray-700 mb-2"
					>Strain Description:
				</label>
				<input
					type="text"
					id="strain-description"
					name="description"
					value=""
					class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors"
				/>
				<label for="strain-type-select">Type: </label>
				<select
					name="type"
					id="strain-type-select"
					class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors bg-white"
				>
					<option value="">-- Select Type --</option>
					<option value="sativa">Sativa</option>
					<option value="indica">Indica</option>
					<option value="hybrid">Hybrid</option>
					<option value="sativa-dominant">Sativa Dominant</option>
					<option value="indica-dominant">Indica Dominant</option>
				</select>
				<button type="submit" class="btn-primary w-full">
					Create New Category
				</button>
			</form>
		</div>
	</body>
</html>

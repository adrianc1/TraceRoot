<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Brands' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen overflow-x-hidden">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-7xl mx-auto px-6 py-8">

        <!-- Page header -->
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-gray-900">Brands</h1>
                <p class="text-sm text-gray-500 font-light mt-0.5"><%= brands.length %> brand<%= brands.length !== 1 ? 's' : '' %> in your company</p>
            </div>
            <a href="/brands/create-brand"
               class="inline-flex items-center justify-center whitespace-nowrap px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors no-underline">
                + New Brand
            </a>
        </div>

        <!-- Table card -->
        <div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
            <div class="overflow-x-auto">

            <table class="w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-50">
                        <th class="text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Name</th>
                        <th class="hidden md:table-cell text-left text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3">Description</th>
                        <th class="text-right text-[0.7rem] font-medium text-gray-600 uppercase tracking-[0.06em] px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% brands.forEach((brand) => { %>
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] font-medium text-gray-900"><%= brand.name %></span>
                        </td>
                        <td class="hidden md:table-cell px-4 py-3 text-[0.8125rem] text-gray-500"><%= brand.description || '' %></td>
                        <td class="px-4 py-3 text-right">
                            <a href="/brands/<%= brand.id %>/edit"
                               class="text-[0.75rem] text-gray-500 hover:text-gray-700 transition-colors font-medium no-underline">
                                Edit
                            </a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>

            </div><!-- /overflow-x-auto -->

            <!-- Empty state -->
            <% if (brands.length === 0) { %>
            <div class="py-16 text-center">
                <div class="text-gray-300 text-4xl mb-3">□</div>
                <p class="text-sm font-medium text-gray-500">No brands yet</p>
                <p class="text-xs text-gray-400 mt-1 mb-4">Create your first brand to get started</p>
                <a href="/brands/create-brand"
                   class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep transition-colors no-underline">
                    New Brand
                </a>
            </div>
            <% } %>

            <!-- Table footer -->
            <% if (brands.length > 0) { %>
            <div class="px-4 py-3 border-t border-gray-100 bg-gray-50">
                <span class="font-mono text-[0.72rem] text-gray-400">
                    <span class="text-gray-600 font-medium"><%= brands.length %></span> brand<%= brands.length !== 1 ? 's' : '' %>
                </span>
            </div>
            <% } %>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>

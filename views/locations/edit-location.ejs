<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Edit Location' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-2xl mx-auto px-6 py-8">

        <!-- Back link -->
        <a href="/locations"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to locations
        </a>

        <!-- Page title -->
        <div class="mb-6">
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">Edit Location</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5"><%= location.name %></p>
        </div>

        <!-- Error partial -->
        <%- include('../partials/errors.ejs') %>

        <!-- Form card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <form id="edit-location-form" data-id="<%= location.id %>">

                <!-- Section: Location Info -->
                <div class="px-6 py-5 border-b border-gray-100">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Location Info</div>
                    <div class="space-y-4">

                        <div>
                            <label for="name" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Location Name <span class="text-red-400">*</span>
                            </label>
                            <input
                                type="text"
                                id="name"
                                name="name"
                                value="<%= location.name %>"
                                required
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white placeholder-gray-300"
                            />
                            <p class="text-[0.75rem] text-gray-400 mt-1">Must be unique within your company</p>
                        </div>

                        <div>
                            <label for="description" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                Description
                                <span class="text-[0.75rem] text-gray-400 font-light ml-1">optional</span>
                            </label>
                            <textarea
                                id="description"
                                name="description"
                                rows="3"
                                class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all resize-none bg-white placeholder-gray-300"
                            ><%= location.description || '' %></textarea>
                        </div>

                        <div class="flex items-center gap-3">
                            <input
                                type="checkbox"
                                id="is_active"
                                name="is_active"
                                value="true"
                                <%= location.is_active ? 'checked' : '' %>
                                class="w-4 h-4 rounded border-gray-300 text-green-mid"
                            />
                            <label for="is_active" class="text-[0.8125rem] font-medium text-gray-700">
                                Active
                                <span class="text-[0.75rem] text-gray-400 font-light ml-1">Inactive locations won't appear in package assignments</span>
                            </label>
                        </div>

                    </div>
                </div>

                <!-- Form actions -->
                <div class="px-6 py-4 bg-gray-50 flex items-center justify-between gap-3">
                    <a href="/locations"
                       class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-white hover:border-gray-400 transition-colors no-underline">
                        Cancel
                    </a>
                    <button
                        type="submit"
                        class="inline-flex items-center justify-center px-5 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer">
                        Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('edit-location-form');

            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                const locationId = form.dataset.id;
                const formData = new FormData(form);
                const data = {
                    name: formData.get('name'),
                    description: formData.get('description'),
                    is_active: formData.get('is_active') === 'true' ? 'true' : 'false',
                };

                const submitBtn = form.querySelector('button[type="submit"]');
                submitBtn.disabled = true;
                submitBtn.textContent = 'Saving...';

                const res = await fetch(`/locations/${locationId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                });

                if (res.ok) {
                    window.location.href = '/locations';
                } else {
                    const err = await res.json();
                    alert(err.error || 'Failed to update location');
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Save Changes';
                }
            });
        });
    </script>

</body>
</html>

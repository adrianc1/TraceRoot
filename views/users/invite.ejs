<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Invite User' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen flex flex-col">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-md mx-auto px-6 py-8 flex-1 w-full">

        <a href="/users"
           class="inline-flex items-center gap-1.5 text-[0.8125rem] text-gray-400 hover:text-gray-700 transition-colors no-underline mb-6">
            ← Back to users
        </a>

        <div class="mb-6">
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">Invite User</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5">Generate an invite link to share with your team</p>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">

            <% if (link) { %>

                <!-- Success state — show the link!! -->
                <div class="px-6 py-5">
                    <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Invite Link Generated</div>
                    <p class="text-[0.8125rem] text-gray-500 mb-3">Copy this link and send it to your teammate. It expires in 48 hours.</p>
                    <div class="flex items-center gap-2">
                        <input
                            type="text"
                            id="invite-link"
                            value="<%= link %>"
                            readonly
                            class="w-full px-3 py-2 text-[0.75rem] font-mono border border-gray-300 rounded-md bg-gray-50 text-gray-600 cursor-text"
                        />
                        <button
                            onclick="copyLink()"
                            id="copy-btn"
                            class="shrink-0 inline-flex items-center justify-center px-4 py-2 text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 transition-colors cursor-pointer">
                            Copy
                        </button>
                    </div>
                </div>

                <div class="px-6 py-4 bg-gray-50 border-t border-gray-100">
                    <a href="/users/invite"
                       class="text-[0.8125rem] font-medium text-green-mid hover:text-green-deep transition-colors no-underline">
                        + Generate another invite
                    </a>
                </div>
            

            <% } else { %>

                <!-- Form state -->
                <form method="POST" action="/users/invite">
                    <div class="px-6 py-5 border-b border-gray-100">
                        <div class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4">Invite Details</div>
                        <div class="space-y-4">

                            <div>
                                <label for="email" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                    Email Address <span class="text-red-400">*</span>
                                </label>
                                <input
                                    type="email"
                                    name="email"
                                    id="email"
                                    placeholder="teammate@example.com"
                                    required
                                    class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white placeholder-gray-300"
                                />
                            </div>

                            <div>
                                <label for="role" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                                    Role <span class="text-red-400">*</span>
                                </label>
                                <select
                                    name="role"
                                    id="role"
                                    required
                                    class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md bg-white text-gray-700">
                                    <option value="">— Select a role —</option>
                                    <option value="admin">Admin</option>
                                    <option value="manager">Manager</option>
                                    <option value="staff">Staff</option>
                                </select>
                                <div class="mt-2 space-y-1">
                                    <p class="text-[0.75rem] text-gray-400"><span class="font-medium text-gray-500">Admin</span> — full access including user management</p>
                                    <p class="text-[0.75rem] text-gray-400"><span class="font-medium text-gray-500">Manager</span> — full inventory access, no user management</p>
                                    <p class="text-[0.75rem] text-gray-400"><span class="font-medium text-gray-500">Staff</span> — view and quantity updates only</p>
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="px-6 py-4 bg-gray-50 flex items-center justify-between gap-3">
                        <a href="/users"
                           class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-white hover:border-gray-400 transition-colors no-underline">
                            Cancel
                        </a>
                        <button
                            type="submit"
                            class="inline-flex items-center justify-center px-5 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer">
                            Generate Link
                        </button>
                    </div>

                </form>

            <% } %>

        </div>
    </div>

    <script>
        function copyLink() {
            const input = document.getElementById('invite-link');
            const btn = document.getElementById('copy-btn');
            navigator.clipboard.writeText(input.value).then(() => {
                btn.textContent = 'Copied!';
                btn.classList.add('text-green-mid', 'border-green-mid');
                setTimeout(() => {
                    btn.textContent = 'Copy';
                    btn.classList.remove('text-green-mid', 'border-green-mid');
                }, 2000);
            });
        }
    </script>

</body>
</html>

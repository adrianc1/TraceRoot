<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/tailwind.css" rel="stylesheet" />
    <title>Invalid Invite — Greenventory</title>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-sm text-center">

        <h1 class="text-xl font-semibold tracking-tight text-gray-900 mb-2">Greenventory</h1>

        <div class="bg-white border border-gray-200 rounded-xl px-8 py-10 mt-6">
            <div class="text-3xl mb-4">⚠️</div>
            <h2 class="text-[0.9375rem] font-semibold text-gray-800 mb-2">This invite is no longer valid</h2>
            <p class="text-[0.8125rem] text-gray-400 leading-relaxed">
                This invite link has either expired or already been used. Ask your admin to generate a new one.
            </p>
        </div>

        <a href="/login"
           class="inline-flex items-center justify-center mt-4 text-[0.8125rem] font-medium text-green-mid hover:text-green-deep transition-colors no-underline">
            ← Back to sign in
        </a>

    </div>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Users' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen flex flex-col">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-4xl mx-auto px-6 py-8 flex-1 w-full">

        <!-- Page header -->
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-gray-900">Users</h1>
                <p class="text-sm text-gray-400 font-light mt-0.5">Manage your team and permissions</p>
            </div>
            <a href="/users/invite"
               class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors no-underline">
                + Invite User
            </a>
        </div>

        <!-- Table card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-50">
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Name</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Email</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Role</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Joined</th>
                        <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% users.forEach(user => { %>
                    <%
                        const roleStyles = {
                            admin:   'bg-green-light text-green-deep',
                            manager: 'bg-blue-50 text-blue-700',
                            staff:   'bg-orange-100 text-orange-500',
                        };
                        const roleStyle = roleStyles[user.role] || 'bg-gray-100 text-gray-500';
                    %>
                    <tr class="hover:bg-gray-50 transition-colors">

                        <!-- Name -->
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2.5">
                                <div class="w-7 h-7 rounded-full bg-gray-100 flex items-center justify-center text-[0.7rem] font-medium text-gray-500">
                                    <%= user.first_name?.charAt(0).toUpperCase() %><%= user.last_name?.charAt(0).toUpperCase() %>
                                </div>
                                <div>
                                    <div class="text-[0.8125rem] font-medium text-gray-900">
                                        <%= user.first_name %> <%= user.last_name %>
                                        <% if (user.id === currentUser.id) { %>
                                            <span class="text-[0.7rem] text-gray-400 font-normal ml-1">(you)</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </td>

                        <!-- Email -->
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] text-gray-500"><%= user.email %></span>
                        </td>

                        <!-- Role badge -->
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded capitalize <%= roleStyle %>">
                                <%= user.role %>
                            </span>
                        </td>

                        <!-- Joined -->
                        <td class="px-4 py-3">
                            <span class="text-[0.8125rem] text-gray-400">
                                <%= new Date(user.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                            </span>
                        </td>

                        <!-- Actions -->
                        <td class="px-4 py-3">
                            <% if (user.id !== currentUser.id) { %>
                                <div class="flex items-center gap-3">
                                    <a href="/users/<%= user.id %>/edit"
                                       class="text-[0.75rem] text-gray-400 hover:text-gray-700 transition-colors font-medium no-underline">
                                        Edit
                                    </a>
                                </div>
                            <% } %>
                        </td>

                    </tr>
                    <% }) %>
                </tbody>
            </table>

            <!-- Empty state -->
            <% if (!users || users.length === 0) { %>
            <div class="py-16 text-center">
                <p class="text-sm font-medium text-gray-500">No users yet</p>
                <p class="text-xs text-gray-400 mt-1 mb-4">Invite your team to get started</p>
                <a href="/users/invite"
                   class="inline-flex items-center justify-center px-4 py-[0.4rem] text-[0.8125rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep transition-colors no-underline">
                    Invite User
                </a>
            </div>
            <% } %>

            <!-- Footer -->
            <% if (users && users.length > 0) { %>
            <div class="px-4 py-3 border-t border-gray-100 bg-gray-50">
                <span class="font-mono text-[0.72rem] text-gray-400">
                    <span class="text-gray-600 font-medium"><%= users.length %></span> users
                </span>
            </div>
            <% } %>

        </div>

        <!-- Pending invites -->
        <% if (pendingInvites && pendingInvites.length > 0) { %>
        <div class="mt-6">
            <h2 class="text-[0.8125rem] font-medium text-gray-700 mb-3">Pending Invites</h2>
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <table class="w-full border-collapse">
                    <thead>
                        <tr class="border-b border-gray-200 bg-gray-50">
                            <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Email</th>
                            <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Role</th>
                            <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3">Expires</th>
                            <th class="text-left text-[0.7rem] font-medium text-gray-400 uppercase tracking-[0.06em] px-4 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% pendingInvites.forEach(invite => { %>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3 text-[0.8125rem] text-gray-500"><%= invite.email %></td>
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center font-mono text-[0.7rem] font-medium px-2 py-[0.2rem] rounded capitalize bg-gray-100 text-gray-500">
                                    <%= invite.role %>
                                </span>
                            </td>
                            <td class="px-4 py-3 text-[0.8125rem] text-gray-400">
                                <%= new Date(invite.expires_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                            </td>
                            <td class="px-4 py-3">
                                <a href="/users/invite/<%= invite.token %>"
                                   class="text-[0.75rem] text-green-mid hover:text-green-deep transition-colors font-medium no-underline">
                                    View Link
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

    </div>

</body>
</html>

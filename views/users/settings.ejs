<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Settings' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen flex flex-col">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-2xl mx-auto px-6 py-8 flex-1 w-full">

        <div class="mb-6">
            <div class="text-[0.8125rem] text-gray-400 mb-2">
                <a href="/users/" class="hover:text-gray-600 transition-colors no-underline">Users</a>
                <span class="mx-1.5">/</span>
                <span>Settings</span>
            </div>
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">Settings</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5">Manage your preferences</p>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <% if (locals.user && locals.user.role === 'admin') { %>
            <div class="px-6 py-5 border-b border-gray-100">
                <div class="text-[0.7rem] font-mono text-gray-700 uppercase tracking-[0.08em]">Team</div>
            </div>
            <div class="px-6 py-5 flex items-center justify-between gap-4 border-b border-gray-100">
                <div>
                    <div class="text-[0.875rem] font-medium text-gray-900">Users</div>
                    <div class="text-[0.8125rem] text-gray-400 mt-0.5">Invite, manage, and view user profiles</div>
                </div>
                <a href="/users"
                   class="inline-flex items-center justify-center whitespace-nowrap shrink-0 px-4 py-[0.4rem] text-[0.8125rem] font-medium text-blue-600 border border-blue-200 rounded-md hover:bg-blue-50 hover:border-blue-300 transition-colors no-underline">
                    View users
                </a>
            </div>
            <% } %>
            <div class="px-6 py-5 border-b border-gray-100">
                <div class="text-[0.7rem] font-mono text-gray-700 uppercase tracking-[0.08em]">Session</div>
            </div>
            <div class="px-6 py-5 flex items-center justify-between gap-4">
                <div>
                    <div class="text-[0.875rem] font-medium text-gray-900">Log out</div>
                    <div class="text-[0.8125rem] text-gray-400 mt-0.5">Sign out of your account on this device</div>
                </div>
                <a href="/logout"
                   class="inline-flex items-center justify-center whitespace-nowrap shrink-0 px-4 py-[0.4rem] text-[0.8125rem] font-medium text-red-600 border border-red-200 rounded-md hover:bg-red-50 hover:border-red-300 transition-colors no-underline">
                    Log out
                </a>
            </div>
        </div>

    </div>

    <%- include('../partials/footer') %>
</body>
</html>

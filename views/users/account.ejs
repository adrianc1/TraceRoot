<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Account' }) %>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen">

    <%- include('../partials/header.ejs') %>

    <div class="max-w-2xl mx-auto px-6 py-8">

        <div class="mb-6">
            <h1 class="text-xl font-semibold tracking-tight text-gray-900">Account</h1>
            <p class="text-sm text-gray-400 font-light mt-0.5">Your personal information</p>
        </div>

        <!-- Profile card -->
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">

            <!-- Avatar + name -->
            <div class="px-6 py-6 border-b border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-green-light flex items-center justify-center shrink-0">
                    <span class="text-[0.9rem] font-semibold text-green-deep font-mono">
                        <%= user.first_name[0].toUpperCase() %><%= user.last_name[0].toUpperCase() %>
                    </span>
                </div>
                <div>
                    <div class="text-[0.9375rem] font-semibold text-gray-900"><%= user.first_name %> <%= user.last_name %></div>
                    <div class="text-[0.8125rem] text-gray-400 mt-0.5 font-mono"><%= user.email %></div>
                </div>
            </div>

            <!-- Fields -->
            <div class="divide-y divide-gray-100">

                <div class="px-6 py-4 flex items-center justify-between">
                    <span class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">First Name</span>
                    <span class="text-[0.875rem] text-gray-900"><%= user.first_name %></span>
                </div>

                <div class="px-6 py-4 flex items-center justify-between">
                    <span class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Last Name</span>
                    <span class="text-[0.875rem] text-gray-900"><%= user.last_name %></span>
                </div>

                <div class="px-6 py-4 flex items-center justify-between">
                    <span class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Email</span>
                    <span class="text-[0.875rem] text-gray-900 font-mono"><%= user.email %></span>
                </div>

                <div class="px-6 py-4 flex items-center justify-between">
                    <span class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Role</span>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[0.75rem] font-medium bg-green-50 text-green-700 capitalize"><%= user.role %></span>
                </div>

                <div class="px-6 py-4 flex items-center justify-between">
                    <span class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em]">Member Since</span>
                    <span class="text-[0.875rem] text-gray-500">
                        <%= new Date(user.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
                    </span>
                </div>

            </div>
        </div>

    </div>

</body>
</html>

					<li><span>/</span></li>
					<li class="text-gray-600">Pricing</li>
				</ol>
			</nav>
		</div>

		<!-- Trial expired banner -->
		<% if (typeof query !== 'undefined' && query.expired) { %>
		<div class="bg-amber-50 border-b border-amber-200 px-6 py-3 text-center">
			<p class="text-[0.8125rem] text-amber-800">Your 14-day trial has ended. Choose a plan below to keep access to your data.</p>
		</div>
		<% } %>

		<!-- HEADER -->
		<section class="max-w-5xl mx-auto px-6 pt-12 pb-10 text-center">

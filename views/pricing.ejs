				<span class="w-5 h-px bg-green-mid inline-block"></span>
				Pricing
				<span class="w-5 h-px bg-green-mid inline-block"></span>
			</div>
			<h1 class="text-[2.25rem] font-semibold leading-[1.2] tracking-tighter text-gray-900 mb-4">
				Simple, transparent pricing
			</h1>
			<p class="text-base text-gray-500 font-light leading-[1.7] max-w-lg mx-auto mb-8">
				Start with a 14-day free trial — no credit card required. Upgrade, downgrade, or cancel any time.
			</p>

			<!-- Billing toggle -->
			<div class="inline-flex items-center gap-3 bg-gray-100 rounded-lg p-1">
				<button
					id="btn-monthly"
					onclick="setBilling('monthly')"
					class="px-4 py-1.5 text-[0.8125rem] font-medium rounded-md transition-all text-gray-500"
				>
					Monthly
				</button>
				<button
					id="btn-annual"
					onclick="setBilling('annual')"
					class="px-4 py-1.5 text-[0.8125rem] font-medium rounded-md transition-all bg-white text-gray-900 shadow-sm"
				>
					Annual
					<span class="ml-1.5 font-mono text-[0.68rem] text-green-mid font-semibold">Save $240</span>
				</button>
			</div>
		</section>

		<!-- PRICING CARDS -->
		<section class="max-w-4xl mx-auto px-6 pb-20">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">

				<!-- Standard -->
				<div class="border border-green-border rounded-xl overflow-hidden bg-white">
					<div class="px-7 pt-7 pb-6 border-b border-gray-100">
						<div class="flex items-center justify-between mb-4">
							<p class="text-[0.8125rem] font-mono font-medium text-gray-500 uppercase tracking-[0.08em]">Standard</p>
							<span class="font-mono text-[0.7rem] px-2 py-[0.2rem] rounded bg-green-light text-green-deep font-medium">14-day free trial</span>
						</div>
						<div class="flex items-end gap-1.5 mb-1">
							<span id="price-display" class="text-[2.75rem] font-semibold tracking-tighter text-gray-900 leading-none">$79</span>
							<span class="text-[0.875rem] text-gray-400 font-light mb-1">/mo</span>
						</div>
						<p id="billing-note" class="text-[0.78rem] text-gray-400 font-light min-h-[1.2rem]">Billed annually — save $240/year</p>
					</div>

					<div class="px-7 py-6">
						<ul class="space-y-3 mb-7">
							<li class="flex items-start gap-3">
								<span class="text-green-mid mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Package & batch tracking</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-green-mid mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Unlimited locations</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-green-mid mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Full audit trail & movement log</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-green-mid mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Transfer management</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-green-mid mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Strain, brand & product catalog</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-green-mid mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Role-based access — admin, manager, staff</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-green-mid mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Up to 10 users</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-green-mid mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Email support</span>
							</li>
						</ul>

						<% if (locals.user) { %>
							<a
								id="checkout-btn"
								href="/billing/checkout?plan=annual"
								class="flex items-center justify-center w-full px-5 py-[0.65rem] text-[0.9rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors no-underline"
							>
								Activate plan
							</a>
							<p class="text-center text-[0.75rem] text-gray-400 font-light mt-3">You'll be taken to a secure checkout</p>
						<% } else { %>
							<a
								href="/signup/create-account"
								class="flex items-center justify-center w-full px-5 py-[0.65rem] text-[0.9rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors no-underline"
							>
								Start free trial
							</a>
							<p class="text-center text-[0.75rem] text-gray-400 font-light mt-3">No credit card required</p>
						<% } %>
					</div>
				</div>

				<!-- Enterprise -->
				<div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
					<div class="px-7 pt-7 pb-6 border-b border-gray-100">
						<div class="flex items-center justify-between mb-4">
							<p class="text-[0.8125rem] font-mono font-medium text-gray-500 uppercase tracking-[0.08em]">Enterprise</p>
							<span class="font-mono text-[0.7rem] px-2 py-[0.2rem] rounded bg-gray-100 text-gray-500 font-medium">Custom</span>
						</div>
						<div class="flex items-end gap-1.5 mb-1">
							<span class="text-[2.75rem] font-semibold tracking-tighter text-gray-900 leading-none">Let's talk</span>
						</div>
						<p class="text-[0.78rem] text-gray-400 font-light min-h-[1.2rem]">Pricing based on your operation's scale</p>
					</div>

					<div class="px-7 py-6">
						<ul class="space-y-3 mb-7">
							<li class="flex items-start gap-3">
								<span class="text-gray-400 mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Everything in Standard</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-gray-400 mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Unlimited users</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-gray-400 mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Multiple organizations</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-gray-400 mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Dedicated onboarding & setup</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-gray-400 mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Priority support with SLA</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-gray-400 mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Team training & onboarding</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-gray-400 mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Dedicated account manager</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-gray-400 mt-0.5 shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								</span>
								<span class="text-[0.8125rem] text-gray-600">Custom contract & billing</span>
							</li>
						</ul>

						<a
							href="/contact"
							class="flex items-center justify-center w-full px-5 py-[0.65rem] text-[0.9rem] font-medium text-gray-700 border border-gray-300 rounded-md hover:bg-gray-50 hover:border-gray-400 transition-colors no-underline"

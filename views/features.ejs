								stroke-linecap="round"
								stroke-linejoin="round"
								d="M19 9l-7 7-7-7"
							/>
						</svg>
					</summary>
					<p
						class="mt-3 text-[0.875rem] text-gray-500 font-light leading-[1.75]"

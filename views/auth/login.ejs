<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/tailwind.css" rel="stylesheet" />
    <title>Login</title>
</head>
<body class="bg-gray-50 font-sans text-gray-900 min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-sm">

        <div class="text-center mb-8">
            	<div
					class="flex mb-4 mr-4 justify-center items-center gap-2 no-underline shrink-0"
				>
					<img
						src="/tracerootheader.png"
						alt="TraceRoot"
						class="h-10 md:h-12"
					/>
				</div>
            <p class="text-sm text-gray-400 font-light mt-1">Sign in to your account</p>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">

            <% if (locals.successMessage) { %>
                <div class="px-6 py-3 bg-green-light border-b border-green-mid/20 flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-green-mid shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm3.707-9.293a1 1 0 0 0-1.414-1.414L9 10.586 7.707 9.293a1 1 0 0 0-1.414 1.414l2 2a1 1 0 0 0 1.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-[0.8125rem] text-green-deep"><%= successMessage %></span>
                </div>
            <% } %>
            <% if (locals.message) { %>
                <div class="px-6 py-3 bg-red-50 border-b border-red-100 flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-red-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10A8 8 0 1 1 2 10a8 8 0 0 1 16 0zm-7-4a1 1 0 1 0-2 0v4a1 1 0 0 0 2 0V6zm-1 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-[0.8125rem] text-red-600"><%= message %></span>
                </div>
            <% } %>

            <form action="/login" method="post" class="px-6 py-6 space-y-4">

                <div>
                    <label for="email" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                        Email
                    </label>
                    <input
                        id="email"
                        name="email"
                        type="email"
                        autocomplete="email"
                        required
                        class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
                    />
                </div>

                <div>
                    <label for="password" class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5">
                        Password
                    </label>
                    <input
                        id="password"
                        name="password"
                        type="password"
                        autocomplete="current-password"
                        required
                        class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
                    />
                </div>

                <button
                    type="submit"
                    class="w-full py-2 text-[0.875rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer mt-2">
                    Sign In
                </button>

                <div class="relative flex items-center py-1">
                    <div class="grow border-t border-gray-200"></div>
                    <span class="mx-3 text-[0.75rem] text-gray-400 shrink-0">or</span>
                    <div class="grow border-t border-gray-200"></div>
                </div>

                <a
                    href="/login/demo"
                    class="block w-full py-2 text-center text-[0.875rem] font-medium text-green-mid bg-white border border-green-mid rounded-md hover:bg-green-light transition-colors no-underline">
                    Try Demo Account
                </a>

            </form>

            <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 text-center">
                <span class="text-[0.8125rem] text-gray-400">Don't have an account?</span>
                <a href="/signup/create-account"
                   class="text-[0.8125rem] font-medium text-green-mid hover:text-green-deep transition-colors ml-1 no-underline">
                    Sign up
                </a>
            </div>

        </div>

    </div>

</body>
</html>

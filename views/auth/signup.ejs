<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link href="/tailwind.css" rel="stylesheet" />
		<title>Sign Up — TraceRoot</title>
	</head>
	<body
		class="bg-gray-50 font-sans text-gray-900 min-h-screen flex items-center justify-center px-4 py-12"
	>
		<div class="w-full max-w-md">
			<div class="text-center mb-8">
				<div
					class="flex mb-4 mr-4 justify-center items-center gap-2 no-underline shrink-0"
				>
					<img
						src="/tracerootheader.png"
						alt="TraceRoot"
						class="h-10 md:h-12"
					/>
				</div>
				<p class="text-sm text-gray-400 font-light mt-1">Create your account</p>
			</div>

			<%- include("../partials/errors.ejs") %>

			<a
				href="/login/demo"
				class="block w-full py-2 mb-4 text-center text-[0.875rem] font-medium text-green-mid bg-white border border-green-mid rounded-md hover:bg-green-light transition-colors no-underline"
			>
				Try Demo Account
			</a>

			<div class="flex items-center mb-4">
				<div class="grow border-t border-gray-200"></div>
				<span class="mx-3 text-[0.75rem] text-gray-400 shrink-0">or create your account</span>
				<div class="grow border-t border-gray-200"></div>
			</div>

			<div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
				<form action="/signup/create-account" method="POST">
					<div class="px-6 py-5 border-b border-gray-100">
						<div
							class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4"
						>
							Your Info
						</div>
						<div class="space-y-4">
							<div class="grid grid-cols-2 gap-4">
								<div>
									<label
										for="firstName"
										class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5"
									>
										First Name
									</label>
									<input
										type="text"
										id="firstName"
										name="firstName"
										value="<%= locals.firstName %>"
										placeholder="Jane"
										class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
									/>
								</div>
								<div>
									<label
										for="lastName"
										class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5"
									>
										Last Name
									</label>
									<input
										type="text"
										id="lastName"
										name="lastName"
										value="<%= locals.lastName %>"
										placeholder="Smith"
										class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
									/>
								</div>
							</div>

							<div>
								<label
									for="email"
									class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5"
								>
									Email Address
								</label>
								<input
									type="email"
									id="email"
									name="email"
									value="<%= locals.email %>"
									placeholder="jane@yourcompany.com"
									autocomplete="email"
									class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
								/>
							</div>

							<div class="grid grid-cols-2 gap-4">
								<div>
									<label
										for="password"
										class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5"
									>
										Password
									</label>
									<input
										type="password"
										id="password"
										name="password"
										placeholder="Min. 8 characters"
										autocomplete="new-password"
										class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
									/>
								</div>
								<div>
									<label
										for="confirmPassword"
										class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5"
									>
										Confirm Password
									</label>
									<input
										type="password"
										id="confirmPassword"
										name="confirmPassword"
										placeholder="Repeat password"
										autocomplete="new-password"
										class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
									/>
								</div>
							</div>
						</div>
					</div>

					<div class="px-6 py-5 border-b border-gray-100">
						<div
							class="text-[0.7rem] font-mono text-gray-400 uppercase tracking-[0.08em] mb-4"
						>
							Business Info
						</div>
						<div class="space-y-4">
							<div>
								<label
									for="company"
									class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5"
								>
									Company Name
								</label>
								<input
									type="text"
									id="company"
									name="company"
									placeholder="Acme Distribution LLC"
									class="w-full px-3 py-2 text-[0.875rem] border border-gray-300 rounded-md transition-all bg-white"
								/>
							</div>

							<div>
								<label
									for="license"
									class="block text-[0.8125rem] font-medium text-gray-700 mb-1.5"
								>
									License Number
								</label>
								<input
									type="text"
									id="license"
									name="license"
									placeholder="C11-0000000-LIC"
									class="w-full px-3 py-2 text-[0.875rem] font-mono border border-gray-300 rounded-md transition-all bg-white"
								/>
							</div>
						</div>
					</div>

					<div class="px-6 py-4 bg-gray-50">
						<button
							type="submit"
							class="w-full py-2 text-[0.875rem] font-medium text-white bg-green-mid border border-green-mid rounded-md hover:bg-green-deep hover:border-green-deep transition-colors cursor-pointer"
						>
							Create Account
						</button>
					</div>
				</form>

				<div class="px-6 py-4 border-t border-gray-100 text-center">
					<span class="text-[0.8125rem] text-gray-400"
						>Already have an account?</span
					>
					<a
						href="/login"
						class="text-[0.8125rem] font-medium text-green-mid hover:text-green-deep transition-colors ml-1 no-underline"
					>
						Sign in
					</a>
				</div>
			</div>
		</div>
	</body>
</html>

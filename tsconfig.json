{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"outDir": "./dist",
		"rootDir": "./",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"allowJs": true,
		"checkJs": false,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": [
		"index.ts",
		"auth/**/*",
		"controllers/**/*",
		"db/**/*",
		"middleware/**/*",
		"routes/**/*",
		"utils/**/*",
		"types/**/*"
	],
	"exclude": ["node_modules", "client", "public", "dist", "tests"]
}
